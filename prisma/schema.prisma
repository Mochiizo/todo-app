generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?  @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  taskLists     TaskList[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TaskList {
  id            Int           @id @default(autoincrement())
  title         String
  date          DateTime      @db.Date
  createdAt     DateTime      @default(now()) @map("created_at")
  note          String?
  notePinned    Boolean       @default(false) @map("note_pinned")
  noteUpdatedAt DateTime?     @map("note_updated_at")
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]
  appointments  Appointment[]

  @@map("task_lists")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isDone      Boolean  @default(false) @map("is_done")
  priority    Priority @default(MEDIUM)
  taskListId  Int      @map("task_list_id")
  taskList    TaskList @relation(fields: [taskListId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Appointment {
  id              Int      @id @default(autoincrement())
  clientLastName  String   @map("client_last_name")
  clientFirstName String   @map("client_first_name")
  formation       String
  time            String
  description     String?
  durationMinutes Int      @default(60) @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  taskListId      Int      @map("task_list_id")
  taskList        TaskList @relation(fields: [taskListId], references: [id], onDelete: Cascade)

  @@map("appointments")
}
